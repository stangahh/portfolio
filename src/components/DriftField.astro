<canvas id="driftCanvas"></canvas>

<script>
(function () {
  const canvas = document.getElementById('driftCanvas');
  const ctx = canvas.getContext('2d');

  /* ── palette ── */
  const WARM  = [196, 122,  58];
  const COOL  = [ 14, 165, 201];
  const CHALK = [235, 230, 220];

  /* ── state ── */
  let W, H;
  let nodes   = [];
  let signals = [];
  let lastScrollY  = 0;
  let scrollVel    = 0;
  let scrollProgress = 0;
  let lastTs   = 0;
  let signalTimer = 0;

  const COUNT       = 70;
  const CONNECT     = 160;   // max line distance
  const MAX_SIGNALS = 20;
  const SIGNAL_INTERVAL = 280; // ms

  /* ── helpers ── */
  const lerp  = (a, b, t) => a + (b - a) * t;
  const clamp = (v, lo, hi) => Math.max(lo, Math.min(hi, v));
  const lerpRGB = (a, b, t) => [lerp(a[0],b[0],t), lerp(a[1],b[1],t), lerp(a[2],b[2],t)];
  const rgba    = (c, a) => `rgba(${c[0]|0},${c[1]|0},${c[2]|0},${a})`;

  /* ── resize ── */
  function resize() {
    W = canvas.width  = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }

  /* ── Particle ── */
  class Particle {
    constructor(full) {
      this.phase  = Math.random() * Math.PI * 2;
      this.freq   = Math.random() * 0.0006 + 0.0003;
      this.r      = Math.random() * 1.3 + 0.4;
      this.baseVx = (Math.random() - 0.5) * 0.35;
      this.baseVy = (Math.random() - 0.5) * 0.35;
      this.x = Math.random() * W;
      this.y = full ? Math.random() * H : -10;
    }

    update(ts, wind) {
      const nx = Math.sin(ts * this.freq + this.phase);
      const ny = Math.cos(ts * this.freq * 0.7 + this.phase + 1.3);
      this.x += this.baseVx + nx * 0.4 + wind.x;
      this.y += this.baseVy + ny * 0.3 + wind.y;
      // wrap
      if (this.x < -60) this.x = W + 60;
      if (this.x > W+60) this.x = -60;
      if (this.y < -60) this.y = H + 60;
      if (this.y > H+60) this.y = -60;
    }
  }

  /* ── Signal (travelling pulse on a connection) ── */
  class Signal {
    constructor(a, b) {
      this.a    = a;
      this.b    = b;
      this.t    = 0;
      this.spd  = Math.random() * 0.009 + 0.004;
      this.done = false;
    }

    update() {
      this.t += this.spd;
      if (this.t >= 1) this.done = true;
    }

    draw(col) {
      const x = lerp(this.a.x, this.b.x, this.t);
      const y = lerp(this.a.y, this.b.y, this.t);
      // glow halo
      const g = ctx.createRadialGradient(x, y, 0, x, y, 7);
      g.addColorStop(0, rgba(col, 0.95));
      g.addColorStop(0.4, rgba(col, 0.3));
      g.addColorStop(1,   rgba(col, 0));
      ctx.fillStyle = g;
      ctx.beginPath();
      ctx.arc(x, y, 7, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  /* ── spawn signal ── */
  function spawnSignal() {
    if (signals.length >= MAX_SIGNALS) return;
    const a = nodes[Math.floor(Math.random() * nodes.length)];
    const near = nodes.filter(n => {
      const d = Math.hypot(n.x - a.x, n.y - a.y);
      return d > 15 && d < CONNECT;
    });
    if (!near.length) return;
    const b = near[Math.floor(Math.random() * near.length)];
    signals.push(new Signal(a, b));
  }

  /* ── init ── */
  function init() {
    resize();
    nodes = Array.from({ length: COUNT }, () => new Particle(true));
  }

  /* ── main loop ── */
  function frame(ts) {
    const dt = ts - lastTs;
    lastTs = ts;
    signalTimer += dt;

    // scroll tracking
    const sy = window.scrollY;
    scrollVel = sy - lastScrollY;
    lastScrollY = sy;
    const maxScroll = document.body.scrollHeight - window.innerHeight;
    scrollProgress = maxScroll > 0 ? clamp(sy / maxScroll, 0, 1) : 0;

    // wind: scroll velocity pushes particles; fast scroll = scatter
    const windStrength = clamp(scrollVel * 0.06, -4, 4);
    const wind = { x: windStrength * 0.15, y: windStrength };

    ctx.clearRect(0, 0, W, H);

    // accent colour shifts warm → cool with scroll depth
    const accent = lerpRGB(WARM, COOL, scrollProgress);

    /* connections */
    for (let i = 0; i < nodes.length; i++) {
      for (let j = i + 1; j < nodes.length; j++) {
        const a = nodes[i], b = nodes[j];
        const d = Math.hypot(a.x - b.x, a.y - b.y);
        if (d < CONNECT) {
          const alpha = (1 - d / CONNECT) * 0.10;
          ctx.strokeStyle = rgba(CHALK, alpha);
          ctx.lineWidth = 0.6;
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b.x, b.y);
          ctx.stroke();
        }
      }
    }

    /* nodes */
    nodes.forEach(n => {
      n.update(ts, wind);
      // brightness spikes with scroll velocity
      const a = clamp(0.25 + Math.abs(scrollVel) * 0.015, 0.1, 0.75);
      ctx.fillStyle = rgba(accent, a);
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
      ctx.fill();
    });

    /* signals */
    if (signalTimer > SIGNAL_INTERVAL) {
      spawnSignal();
      signalTimer = 0;
    }
    signals = signals.filter(s => !s.done);
    signals.forEach(s => { s.update(); s.draw(accent); });

    requestAnimationFrame(frame);
  }

  window.addEventListener('resize', resize);
  init();
  requestAnimationFrame(frame);
})();
</script>

<style>
  #driftCanvas {
    position: fixed;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    opacity: 0.9;
  }
</style>
