---
import Base from '../layouts/Base.astro';

const links = [
  {
    category: "Code",
    items: [
      { label: "GitHub", handle: "@stangahh", url: "https://github.com/stangahh", description: "All my open source work and experiments" },
    ]
  },
  {
    category: "Social",
    items: [
      { label: "LinkedIn", handle: "/in/stangahh", url: "https://www.linkedin.com/in/stangahh/", description: "Professional network and career" },
    ]
  },
  {
    category: "Contact",
    items: [
      { label: "Email", handle: "me@stangahh.dev", url: "mailto:me+links@stangahh.dev", description: "Best way to reach me" },
    ]
  },
];
---
<Base title="Links — Jesse Stanger" description="Where to find Jesse Stanger online.">
  <section class="page-hero">
    <p class="label fade-up fade-up-1">links</p>
    <h1 class="fade-up fade-up-2">Where to<br/><em>find me.</em></h1>
  </section>

  <section class="section-narrow">
    <div class="divider"></div>
    {links.map(group => (
      <div class="link-group">
        <p class="label">{group.category}</p>
        <div class="link-list">
          {group.items.map(item => (
            <a href={item.url} target={item.url.startsWith('http') ? "_blank" : "_self"} rel="noopener" class="link-card">
              <div class="link-left">
                <span class="link-platform">{item.label}</span>
                <span class="link-handle">{item.handle}</span>
              </div>
              <span class="link-desc">{item.description}</span>
              <span class="link-arrow">→</span>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
</Base>

<style>
  .section-narrow {
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  .link-group { display: flex; flex-direction: column; gap: 0; }

  .link-group > .label { margin-bottom: 24px; }

  .link-list { display: flex; flex-direction: column; }

  .link-card {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 20px 0;
    border-bottom: 1px solid var(--chalk-faint);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .link-card:first-child { border-top: 1px solid var(--chalk-faint); }
  .link-card:hover { opacity: 0.75; }

  .link-left {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 160px;
  }

  .link-platform {
    font-family: "Instrument Sans", sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--chalk-bright);
  }

  .link-handle {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--warm);
    letter-spacing: 1px;
  }

  .link-desc {
    font-size: 13px;
    color: var(--chalk-dim);
    font-style: italic;
    flex: 1;
  }

  .link-arrow {
    font-family: "JetBrains Mono", monospace;
    color: var(--warm);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .link-card:hover .link-arrow { opacity: 1; }

  @media (max-width: 768px) {
    .section-narrow {
      gap: 48px;
    }

    .link-group > .label {
      margin-bottom: 16px;
    }

    .link-card {
      gap: 12px;
      padding: 16px 0;
      flex-wrap: wrap;
    }

    .link-left {
      gap: 4px;
    }

    .link-platform {
      font-size: 12px;
    }

    .link-handle {
      font-size: 11px;
    }

    .link-desc {
      font-size: 12px;
      flex: 100%;
    }

    .link-arrow {
      opacity: 1;
      font-size: 12px;
    }
  }
</style>
