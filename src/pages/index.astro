---
import Base from '../layouts/Base.astro';
---
<Base title="Your Name — Engineer. Builder." description="Personal site of Your Name.">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <p class="label fade-up fade-up-1">engineer · builder · human</p>
      <h1 class="hero-title fade-up fade-up-2">
        Your<br/><em>Name</em>
      </h1>
      <p class="hero-sub fade-up fade-up-3">
        Building things that matter, one commit at a time.
      </p>
      <div class="hero-cta fade-up fade-up-4">
        <a href="/about" class="btn-primary">about me →</a>
        <a href="/projects" class="btn-ghost">see my work</a>
      </div>
    </div>
    <div class="hero-scroll">scroll</div>
  </section>

  <!-- Currently -->
  <section class="section-narrow">
    <div class="divider"></div>
    <div class="currently">
      <p class="label">currently</p>
      <div class="currently-items">
        <div class="currently-item">
          <span class="num">01</span>
          <div>
            <strong>Role</strong>
            <p>Senior Engineer @ Some Company</p>
          </div>
        </div>
        <div class="currently-item">
          <span class="num">02</span>
          <div>
            <strong>Building</strong>
            <p>Something interesting on the side</p>
          </div>
        </div>
        <div class="currently-item">
          <span class="num">03</span>
          <div>
            <strong>Reading</strong>
            <p>Whatever's interesting this week</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="section-narrow">
    <div class="divider"></div>
    <div class="section-header">
      <p class="label">selected work</p>
      <h2>Projects</h2>
    </div>
    <div class="project-list">
      <article class="project-card">
        <span class="num">01</span>
        <div class="project-body">
          <h3>Project Name</h3>
          <p>A short description of what this does and why it matters. Built with TypeScript and curiosity.</p>
          <div class="project-tags">
            <span class="tag">TypeScript</span>
            <span class="tag">Rust</span>
            <span class="tag">Postgres</span>
          </div>
          <div class="project-links">
            <a href="https://github.com" target="_blank" rel="noopener">github →</a>
            <a href="#" target="_blank" rel="noopener">live →</a>
          </div>
        </div>
      </article>
      <article class="project-card">
        <span class="num">02</span>
        <div class="project-body">
          <h3>Another Project</h3>
          <p>What this does. The interesting technical problem it solves and what you learned building it.</p>
          <div class="project-tags">
            <span class="tag">Go</span>
            <span class="tag">Docker</span>
          </div>
          <div class="project-links">
            <a href="https://github.com" target="_blank" rel="noopener">github →</a>
          </div>
        </div>
      </article>
      <article class="project-card">
        <span class="num">03</span>
        <div class="project-body">
          <h3>Third Thing</h3>
          <p>Brief description. Keep it honest, keep it interesting.</p>
          <div class="project-tags">
            <span class="tag">Python</span>
            <span class="tag">ML</span>
          </div>
          <div class="project-links">
            <a href="https://github.com" target="_blank" rel="noopener">github →</a>
          </div>
        </div>
      </article>
    </div>
    <a href="/projects" class="see-all">all projects →</a>
  </section>

  <!-- Skills -->
  <section class="section-narrow">
    <div class="divider"></div>
    <div class="section-header">
      <p class="label">toolkit</p>
      <h2>Skills</h2>
    </div>
    <div class="skills-grid">
      <div class="skill-group">
        <h3 class="skill-group-title">Languages</h3>
        <ul>
          <li>TypeScript / JavaScript</li>
          <li>Rust</li>
          <li>Go</li>
          <li>Python</li>
          <li>SQL</li>
        </ul>
      </div>
      <div class="skill-group">
        <h3 class="skill-group-title">Infrastructure</h3>
        <ul>
          <li>Docker / Kubernetes</li>
          <li>AWS / GCP</li>
          <li>Terraform</li>
          <li>CI/CD</li>
        </ul>
      </div>
      <div class="skill-group">
        <h3 class="skill-group-title">Domains</h3>
        <ul>
          <li>Distributed Systems</li>
          <li>Developer Tooling</li>
          <li>AI / Agents</li>
          <li>Platform Engineering</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Writing -->
  <section class="section-narrow">
    <div class="divider"></div>
    <div class="section-header">
      <p class="label">writing</p>
      <h2>Recent Posts</h2>
    </div>
    <div class="post-list">
      <a href="/writing/post-one" class="post-item">
        <span class="post-date">Apr 2026</span>
        <h3>Something I figured out</h3>
        <p>A short teaser about what the post covers and why it's worth reading.</p>
      </a>
      <a href="/writing/post-two" class="post-item">
        <span class="post-date">Mar 2026</span>
        <h3>Another thing worth writing about</h3>
        <p>Brief teaser.</p>
      </a>
    </div>
    <a href="/writing" class="see-all">all posts →</a>
  </section>
</Base>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 0 clamp(24px, 6vw, 120px);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .hero-title {
    font-size: clamp(64px, 10vw, 140px);
    font-weight: 700;
    line-height: 0.9;
    margin: 8px 0;
    color: rgba(235,230,220,.95);
  }

  .hero-sub {
    font-family: Spectral, serif;
    font-size: clamp(16px, 1.8vw, 22px);
    font-weight: 300;
    font-style: italic;
    color: var(--warm-sub);
    max-width: 520px;
  }

  .hero-cta {
    display: flex;
    gap: 20px;
    margin-top: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-primary {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: lowercase;
    color: var(--bg);
    background: var(--warm);
    padding: 10px 24px;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.85; }

  .btn-ghost {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    letter-spacing: 3px;
    text-transform: lowercase;
    color: var(--warm);
    border: 1px solid var(--warm-border);
    padding: 10px 24px;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-ghost:hover { border-color: var(--warm); color: var(--chalk-bright); }

  .hero-scroll {
    position: fixed;
    bottom: 28px;
    left: 0;
    right: 0;
    text-align: center;
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--chalk-dim);
    z-index: 15;
    animation: fadeIn 1s ease 1.8s forwards;
    opacity: 0;
  }

  .hero-scroll::after {
    content: "";
    display: block;
    width: 1px;
    height: 28px;
    background: linear-gradient(to bottom, var(--warm), transparent);
    margin: 8px auto 0;
  }

  @keyframes fadeIn { to { opacity: 1; } }

  .section-narrow {
    max-width: 800px;
    margin: 0 auto;
    padding: clamp(60px, 10vh, 120px) clamp(24px, 4vw, 60px);
  }

  .section-header { margin-bottom: 48px; }
  .section-header h2 { font-size: clamp(36px, 5vw, 64px); margin-top: 12px; }

  .currently { padding-top: 48px; }
  .currently .label { margin-bottom: 32px; display: block; }
  .currently-items { display: flex; flex-direction: column; gap: 24px; }
  .currently-item { display: flex; gap: 24px; align-items: flex-start; }

  .num {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--warm-num);
    letter-spacing: 2px;
    padding-top: 3px;
    min-width: 28px;
  }

  .currently-item strong {
    font-family: "Instrument Sans", sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 4px;
    text-transform: uppercase;
    display: block;
    margin-bottom: 4px;
    color: var(--warm);
  }

  .currently-item p { font-size: 15px; color: var(--chalk-dim); }

  .project-list { display: flex; flex-direction: column; }

  .project-card {
    display: flex;
    gap: 28px;
    padding: 36px 0;
    border-bottom: 1px solid var(--chalk-faint);
  }

  .project-card:first-child { border-top: 1px solid var(--chalk-faint); }
  .project-body { flex: 1; }
  .project-body h3 { font-size: clamp(20px, 2.5vw, 28px); margin-bottom: 10px; }
  .project-body p { font-size: 15px; color: var(--chalk-dim); line-height: 1.7; margin-bottom: 16px; }

  .project-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }

  .tag {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--cool);
    border: 1px solid var(--cool-border);
    padding: 3px 10px;
  }

  .project-links { display: flex; gap: 20px; }

  .project-links a {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--warm);
    transition: opacity 0.2s;
  }

  .project-links a:hover { opacity: 0.7; }

  .see-all {
    display: inline-block;
    margin-top: 40px;
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 3px;
    color: var(--chalk-dim);
    transition: color 0.2s;
  }

  .see-all:hover { color: var(--warm); }

  .skills-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 40px; }

  .skill-group-title {
    font-family: "Instrument Sans", sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--warm);
    margin-bottom: 16px;
  }

  .skill-group ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }

  .skill-group li {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.5px;
    color: var(--chalk-dim);
  }

  .post-list { display: flex; flex-direction: column; }

  .post-item {
    display: block;
    padding: 32px 0;
    border-bottom: 1px solid var(--chalk-faint);
    transition: opacity 0.2s;
  }

  .post-item:first-child { border-top: 1px solid var(--chalk-faint); }
  .post-item:hover { opacity: 0.75; }

  .post-date {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--warm-num);
    text-transform: uppercase;
    display: block;
    margin-bottom: 8px;
  }

  .post-item h3 { font-size: clamp(18px, 2vw, 24px); margin-bottom: 8px; color: var(--chalk-bright); }
  .post-item p { font-size: 14px; color: var(--chalk-dim); font-style: italic; }
</style>
