---
import Base from '../layouts/Base.astro';
import TreeRings from '../components/TreeRings.astro';
import { getCollection } from 'astro:content';
import { projects } from '../data/projects';
import { skillGroups } from '../data/skills';
import { findSkillTag } from '../lib/tagify';

const allPosts = await getCollection('writing');
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const recentPosts = allPosts.slice(0, 2);
const hasRecentPosts = recentPosts.length > 0;
const featuredProjects = projects.slice(0, 3);
---
<Base title="Jesse Stanger — Senior Full Stack Engineer" description="Senior Full Stack Software Engineer based in Melbourne.">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <p class="label fade-up fade-up-1">senior full stack engineer · ai-accelerated</p>
      <h1 class="hero-title fade-up fade-up-2">
        Jesse<br/><span class="hero-surname">Stanger</span>
      </h1>
      <p class="hero-sub fade-up fade-up-3">
        Eight years of full-stack engineering on complex systems. Startup to enterprise scale. Obsessive attention to detail, uncompromising quality.
      </p>
      <div class="hero-cta fade-up fade-up-4">
        <a href="/about" class="btn-primary">about me →</a>
        <a href="/projects" class="btn-ghost">see my work</a>
      </div>
    </div>
  </section>

  <!-- Currently -->
  <section class="section-narrow">
    <div class="divider"></div>
    <div class="currently">
      <p class="label">currently</p>
      <div class="currently-items">
        <div class="currently-item">
          <span class="num">01</span>
          <div>
            <strong>Role</strong>
            <p>Senior Full Stack Engineer @ Versent</p>
          </div>
        </div>
        <div class="currently-item">
          <span class="num">02</span>
          <div>
            <strong>Focus</strong>
            <p>AI-accelerated engineering — custom Claude agents, MCP servers, and codebase-specific tooling that multiplies team throughput.</p>
          </div>
        </div>
        <div class="currently-item">
          <span class="num">03</span>
          <div>
            <strong>Building</strong>
            <p>This site, tools that make my workflow faster, dialing in my coffee ☕</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tree Ring Growth -->
  <TreeRings />

  <!-- Featured Projects -->
  <section class="section-narrow">
    <div class="divider"></div>
    <div class="section-header">
      <p class="label">selected work</p>
      <h2>Projects</h2>
    </div>
    <div class="project-list">
      {featuredProjects.map(p => (
        <article class="project-card">
          <span class="num">{p.year}</span>
          <div class="project-body">
            <h3>{p.name}</h3>
            <p>{p.description}</p>
            <div class="project-tags">
              {p.tags.map(t => <a href={`/projects?tech=${t.toLowerCase()}`} class="tag">{t}</a>)}
            </div>
          </div>
        </article>
      ))}
    </div>
    <a href="/projects" class="see-all">all projects →</a>
  </section>

  <!-- Skills -->
  <section class="section-narrow">
    <div class="divider"></div>
    <div class="section-header">
      <p class="label">toolkit</p>
      <h2>Skills</h2>
    </div>
    <div class="skills-grid">
      {skillGroups.map(group => (
        <div class="skill-group">
          <h3 class="skill-group-title">{group.title}</h3>
          <ul>
            {group.skills.map(skill => {
                const tag = findSkillTag(skill);
                return tag
                  ? <li><a href={`/projects?tech=${tag.toLowerCase()}`} class="skill-link">{skill}</a></li>
                  : <li>{skill}</li>;
              })}
          </ul>
        </div>
      ))}
    </div>
    <p class="skills-callout"><a href="/projects">explore more by technology in project filters →</a></p>
  </section>

  {hasRecentPosts && (
    <section class="section-narrow">
      <div class="divider"></div>
      <div class="section-header">
        <p class="label">writing</p>
        <h2>Recent Posts</h2>
      </div>
      <div class="post-list">
        {recentPosts.map(post => (
          <a href={`/writing/${post.id}`} class="post-item">
            <span class="post-date">{post.data.date.toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
          </a>
        ))}
      </div>
      <a href="/writing" class="see-all">all posts →</a>
    </section>
  )}
</Base>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 0 clamp(24px, 6vw, 120px);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .hero-title {
    font-family: "Playfair Display", serif;
    font-size: clamp(64px, 10vw, 140px);
    font-weight: 700;
    font-style: normal;
    line-height: 0.9;
    margin: 8px 0;
    color: rgba(235,230,220,.95);
  }

  .hero-surname { color: var(--warm); font-style: normal; }

  .hero-sub {
    font-family: Spectral, serif;
    font-size: clamp(16px, 1.8vw, 22px);
    font-weight: 300;
    font-style: italic;
    color: var(--warm-sub);
    max-width: 520px;
  }

  .hero-cta {
    display: flex;
    gap: 20px;
    margin-top: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 80vh;
      padding: 0 16px;
    }

    .hero-title {
      font-size: clamp(40px, 8vw, 80px);
    }

    .hero-sub {
      font-size: clamp(14px, 1.5vw, 18px);
      max-width: 100%;
    }

    .hero-cta {
      gap: 12px;
    }
  }

  .section-header { margin-bottom: 48px; }
  .section-header h2 { font-size: clamp(36px, 5vw, 64px); margin-top: 12px; }

  .currently { padding-top: 48px; }
  .currently .label { margin-bottom: 32px; display: block; }
  .currently-items { display: flex; flex-direction: column; gap: 24px; }
  .currently-item { display: flex; gap: 24px; align-items: flex-start; }

  .currently-item strong {
    font-family: "Instrument Sans", sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 4px;
    text-transform: uppercase;
    display: block;
    margin-bottom: 4px;
    color: var(--warm);
  }

  .currently-item p { font-size: 15px; color: var(--chalk-dim); }

  .project-list { display: flex; flex-direction: column; }

  .project-card {
    display: flex;
    gap: 28px;
    padding: 36px 0;
    border-bottom: 1px solid var(--chalk-faint);
  }

  .project-card:first-child { border-top: 1px solid var(--chalk-faint); }

  .project-card .num {
    width: 100px;
    flex-shrink: 0;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .project-card {
      flex-direction: column;
      gap: 6px;
      padding: 24px 0;
    }

    .project-card .num {
      width: auto;
    }
  }

  .project-body { flex: 1; }
  .project-body h3 { font-size: clamp(20px, 2.5vw, 28px); margin-bottom: 10px; }
  .project-body p { font-size: 15px; color: var(--chalk-dim); line-height: 1.7; margin-bottom: 16px; }

  .project-tags { display: flex; gap: 8px; flex-wrap: wrap; }

  .tag {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--cool);
    border: 1px solid var(--cool-border);
    padding: 3px 10px;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .tag:hover { opacity: 0.7; }

  .skills-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 40px; }

  .skill-group-title {
    font-family: "Instrument Sans", sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--warm);
    margin-bottom: 16px;
  }

  .skill-group ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }

  .skill-group li {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    letter-spacing: 0.5px;
    color: var(--chalk-dim);
  }

  .skill-link {
    color: var(--chalk-dim);
    text-decoration: none;
    transition: color 0.2s;
  }

  .skill-link:hover {
    color: var(--warm);
  }

  .skills-callout {
    margin-top: 32px;
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 1.5px;
  }

  .skills-callout a {
    color: var(--warm);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .skills-callout a:hover { opacity: 0.7; }

  .post-list { display: flex; flex-direction: column; }

  .post-item {
    display: block;
    padding: 32px 0;
    border-bottom: 1px solid var(--chalk-faint);
    transition: opacity 0.2s;
  }

  .post-item:first-child { border-top: 1px solid var(--chalk-faint); }
  .post-item:hover { opacity: 0.75; }

  .post-date {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--warm-num);
    text-transform: uppercase;
    display: block;
    margin-bottom: 8px;
  }

  .post-item h3 { font-size: clamp(18px, 2vw, 24px); margin-bottom: 8px; color: var(--chalk-bright); }
  .post-item p { font-size: 14px; color: var(--chalk-dim); font-style: italic; }
</style>

