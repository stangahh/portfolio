---
import Base from '../layouts/Base.astro';
import { projects } from '../data/projects';

const allTechs = [...new Set(projects.flatMap(p => p.tags))];
const activeCount = projects.filter(p => p.status === "active").length;
const archivedCount = projects.filter(p => p.status === "archived").length;
---
<Base title="Projects — Jesse Stanger" description="Things I've built.">
  <div class="projects-wrap">

    <header class="editorial-hero">
      <p class="label fade-up fade-up-1">work</p>
      <h1 class="fade-up fade-up-2">Things I've<br/><em>built.</em></h1>
    </header>

    <div class="projects-layout">

      <!-- Sidebar: stats + tech filters -->
      <aside class="projects-sidebar">
        <p class="sidebar-section-label">the work</p>

        <div class="stats">
          <div class="stat">
            <span class="stat-num">{projects.length}</span>
            <span class="stat-label">projects</span>
          </div>
          <div class="stat">
            <span class="stat-num">{activeCount}</span>
            <span class="stat-label">active</span>
          </div>
          <div class="stat">
            <span class="stat-num">{archivedCount}</span>
            <span class="stat-label">archived</span>
          </div>
          <div class="stat">
            <span class="stat-num">{allTechs.length}</span>
            <span class="stat-label">technologies</span>
          </div>
        </div>

        <div class="tech-cloud">
          <button class="tech-btn active" data-tech="all">all</button>
          {allTechs.map(tech => (
            <button class="tech-btn" data-tech={tech.toLowerCase()}>{tech}</button>
          ))}
        </div>
      </aside>

      <!-- Main: editorial project blocks -->
      <main class="projects-main" id="projectsMain">
        {projects.map(p => (
          <article
            class="project-block"
            data-techs={p.tags.map(t => t.toLowerCase()).join(' ')}
            data-status={p.status}
          >
            <div class="block-eyebrow">
              <span class="block-num">{p.num}</span>
              <span class="block-year">{p.year}</span>
              {p.status === "archived" && <span class="archived-pill">archived</span>}
            </div>
            <h2 class="block-title">{p.name}</h2>
            <p class="block-desc">{p.description}</p>
            <div class="block-techs">
              {p.tags.map(t => <span class="block-tech">{t}</span>)}
            </div>
            <div class="block-links">
              {p.github && <a href={p.github} target="_blank" rel="noopener">github →</a>}
              {p.live && <a href={p.live} target="_blank" rel="noopener">live →</a>}
            </div>
          </article>
        ))}
        <p class="no-results" id="noResults">No projects match that filter.</p>
      </main>

    </div>
  </div>
</Base>

<style>
  .projects-wrap { padding-top: 80px; }

  /* ── Two-column layout ── */
  .projects-layout {
    display: flex;
    max-width: 1200px;
    margin: 0 auto 80px;
    border-top: 1px solid var(--chalk-faint);
    min-height: 60vh;
  }

  /* ── Sidebar ── */
  .projects-sidebar {
    width: 200px;
    flex-shrink: 0;
    padding: 32px 0;
    border-right: 1px solid var(--chalk-faint);
    position: sticky;
    top: 80px;
    height: fit-content;
    overflow: hidden;
  }

  .sidebar-section-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--chalk-dim);
    padding: 0 20px;
    margin-bottom: 24px;
  }

  /* ── Stats ── */
  .stats {
    padding: 0 20px;
    margin-bottom: 32px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .stat-num {
    font-family: "Cormorant Garamond", serif;
    font-size: 36px;
    font-weight: 700;
    color: var(--chalk-bright);
    line-height: 1;
  }

  .stat-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--chalk-dim);
  }

  /* ── Tech cloud ── */
  .tech-cloud {
    padding: 10px 20px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    border-top: 1px solid var(--chalk-faint);
    margin-top: 8px;
  }

  .tech-btn {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 1px;
    color: var(--chalk-dim);
    background: none;
    border: 0.667px solid var(--chalk-faint);
    padding: 3px 8px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
    text-transform: lowercase;
  }

  .tech-btn:hover {
    color: var(--chalk);
    border-color: rgba(235, 230, 220, 0.25);
  }

  .tech-btn.active {
    color: var(--warm);
    border-color: var(--warm-border);
    background: rgba(196, 122, 58, 0.06);
  }

  /* ── Main feed ── */
  .projects-main {
    flex: 1;
    padding: 0 30px 120px;
    min-width: 0;
  }

  /* ── Project block ── */
  .project-block {
    padding: 48px 0;
    border-bottom: 1px solid var(--chalk-faint);
    transition: opacity 0.3s ease, max-height 0.3s ease, padding 0.3s ease, margin 0.3s ease;
    max-height: 2000px;
    overflow: hidden;
  }

  .project-block.hidden {
    opacity: 0;
    max-height: 0;
    padding: 0;
    border: none;
    pointer-events: none;
  }

  .block-eyebrow {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .block-num {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--warm-num);
  }

  .block-year {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--chalk-dim);
  }

  .archived-pill {
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--chalk-dim);
    border: 0.667px solid var(--chalk-faint);
    padding: 2px 8px;
  }

  .block-title {
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 700;
    color: var(--chalk-bright);
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .block-desc {
    font-size: 15px;
    color: var(--chalk-dim);
    line-height: 1.8;
    max-width: 620px;
    margin-bottom: 20px;
  }

  .block-techs {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 20px;
  }

  .block-tech {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 1px;
    color: var(--chalk);
    border: 0.667px solid rgba(235, 230, 220, 0.12);
    padding: 2px 8px;
  }

  .block-links {
    display: flex;
    gap: 20px;
  }

  .block-links a {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--warm);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .block-links a:hover { opacity: 0.7; }

  .no-results {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    letter-spacing: 2px;
    color: var(--chalk-dim);
    padding: 48px 0;
    text-transform: uppercase;
    opacity: 0;
    max-height: 0;
    transition: opacity 0.3s ease, max-height 0.3s ease, padding 0.3s ease;
    overflow: hidden;
  }

  .no-results.visible {
    opacity: 1;
    max-height: 200px;
  }

  @media (max-width: 768px) {
    .projects-wrap { padding-top: 60px; }

    .projects-layout {
      flex-direction: column;
      gap: 0;
      border: none;
      min-height: auto;
      margin-bottom: 80px;
    }

    .projects-sidebar {
      width: 100%;
      flex-shrink: 1;
      padding: 24px 16px;
      border-right: none;
      border-bottom: 1px solid var(--chalk-faint);
      position: static;
      height: auto;
      max-height: none;
      overflow: hidden;
      display: flex;
      flex-direction: row;
      gap: 24px;
      flex-wrap: wrap;
      align-items: flex-start;
      order: -1;
    }

    .sidebar-section-label {
      padding: 0;
      margin-bottom: 0;
      width: 100%;
      flex-basis: 100%;
    }

    .stats {
      padding: 0;
      margin-bottom: 0;
      flex: 1;
      min-width: 150px;
    }

    .tech-cloud {
      padding: 0;
      border: none;
      padding-top: 0;
      padding-bottom: 0;
      margin-top: 0;
      flex: 1;
      min-width: 150px;
    }

    .projects-main {
      padding: 24px 16px 120px;
    }

    .project-block {
      padding: 24px 16px;
    }

    .project-block.hidden {
      padding: 0;
    }

    .block-title {
      font-size: clamp(20px, 5vw, 28px);
    }

    .block-desc {
      font-size: 14px;
    }

    .block-tech {
      font-size: 10px;
    }

    .block-links a {
      font-size: 10px;
    }
  }
</style>

<script>
  function initProjects() {
    const techBtns = document.querySelectorAll<HTMLButtonElement>('.tech-btn');
    const blocks = document.querySelectorAll<HTMLElement>('.project-block');
    const noResults = document.getElementById('noResults');

    if (!techBtns.length || !blocks.length) return;

    // Prevent duplicate initialization
    if (techBtns[0]._hasFilterListener) return;
    techBtns.forEach(btn => { btn._hasFilterListener = true; });

    let activeTech = 'all';

    function filter() {
      let visible = 0;
      blocks.forEach(block => {
        const techs = block.dataset.techs || '';
        const show = activeTech === 'all' || techs.includes(activeTech);
        block.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      if (noResults) noResults.classList.toggle('visible', visible === 0);
    }

    techBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        techBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeTech = btn.dataset.tech || 'all';
        filter();
      });
    });
  }

  // Run on initial load
  if (document.readyState === 'complete') {
    initProjects();
  } else {
    window.addEventListener('load', initProjects);
  }

  // Run after view transitions
  document.addEventListener('astro:page-load', initProjects);
</script>
