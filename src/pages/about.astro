---
import Base from '../layouts/Base.astro';
import { experiences } from '../data/experiences';
import { tagify } from '../lib/tagify';

const sortedExperiences = [...experiences].sort((a, b) => {
  if (!a.endDate) return -1;
  if (!b.endDate) return 1;
  return new Date(b.endDate).getTime() - new Date(a.endDate).getTime();
});
---
<Base title="About — Jesse Stanger" description="About Jesse Stanger.">
  <section class="page-hero">
    <p class="label fade-up fade-up-1">about</p>
    <h1 class="fade-up fade-up-2">The lead<br/>behind the delivery.</h1>
  </section>

  <section class="section-narrow">
    <div class="divider"></div>
    <div class="bio">
      <p set:html={tagify(`I'm a Senior Full Stack Engineer and technical lead based in <strong>Melbourne</strong>, with 8 years of experience across startups and enterprises. I take ownership of epics end-to-end — from backlog and solution design through execution and release. I mentor engineers, present to stakeholders, and build the frameworks and tooling that multiply team throughput.`)} />
      <p set:html={tagify(`Currently at <strong>Versent</strong>. Owning complex payment system epics at a major Australian bank — designing solutions, breaking down work into Jira backlogs, presenting to the team, and leading delivery through to production. Pioneering AI-accelerated practices across the team through open forum demos, tooling distribution, and custom MCP configurations.`)} />
      <p set:html={tagify(`My messages are hyperlinked so everyone can follow along. I reliably return to ongoing conversations and have a track record for ownership across distributed teams. I believe in simple, honest code and working with people who care about quality.`)} />
    </div>
  </section>

  <section class="section-narrow">
    <div class="divider"></div>
    <p class="label">experience</p>
    <div class="timeline">
      {sortedExperiences.map((exp) => (
        <div class={`timeline-item ${exp.canstarGroup ? 'canstar-group' : ''}`}>
          <div class="timeline-meta">
            <span class="num">{exp.type}</span>
            <span class="timeline-date">{exp.dateDisplay}</span>
          </div>
          <div class="timeline-body">
            <h2>{exp.title}</h2>
            <p class="timeline-company">{exp.company}</p>
            {exp.description && <p set:html={tagify(exp.description)} />}
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section-narrow">
    <div class="divider"></div>
    <p class="label">find me</p>
    <div class="links-grid">
      <a href="https://github.com/stangahh" target="_blank" rel="noopener" class="link-card">
        <span class="link-platform">GitHub</span>
        <span class="link-handle">@stangahh</span>
        <span class="link-arrow">→</span>
      </a>
      <a href="https://www.linkedin.com/in/stangahh/" target="_blank" rel="noopener" class="link-card">
        <span class="link-platform">LinkedIn</span>
        <span class="link-handle">/in/stangahh</span>
        <span class="link-arrow">→</span>
      </a>
      <a href="mailto:me+about@stangahh.dev" target="_blank" rel="noopener" class="link-card">
        <span class="link-platform">Email</span>
        <span class="link-handle">me@stangahh.dev</span>
        <span class="link-arrow">→</span>
      </a>
    </div>
  </section>
</Base>

<style>

.bio {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding-top: 40px;
  }

  .bio p {
    font-size: clamp(16px, 1.6vw, 19px);
    font-weight: 300;
    line-height: 1.9;
    color: rgba(235,230,220,.8);
  }

  .timeline {
    margin-top: 40px;
    display: flex;
    flex-direction: column;
  }

  .timeline-item {
    display: flex;
    gap: 32px;
    padding: 36px 0;
    border-bottom: 1px solid var(--chalk-faint);
  }

  .timeline-item:first-child { border-top: 1px solid var(--chalk-faint); }

  .timeline-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
    width: 90px;
    flex-shrink: 0;
  }

  .timeline-item.canstar-group {
    position: relative;
  }

  .timeline-item.canstar-group::before {
    content: "";
    position: absolute;
    left: -20px;
    top: 24px;
    bottom: -20px;
    width: 2px;
    background: repeating-linear-gradient(
      to bottom,
      var(--chalk-faint) 0,
      var(--chalk-faint) 4px,
      transparent 4px,
      transparent 8px
    );
  }

  .timeline-item.canstar-group:first-child::before {
    top: 10px;
  }

.timeline-date {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--chalk-dim);
  }

  .timeline-body { flex: 1; }

  .timeline-body h2 {
    font-size: clamp(18px, 2vw, 24px);
    margin-bottom: 4px;
  }

  .timeline-company {
    font-family: "Instrument Sans", sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--warm);
    margin-bottom: 12px;
    display: block;
  }

  .timeline-body p:last-child {
    font-size: 14px;
    color: var(--chalk-dim);
    line-height: 1.7;
  }

  .links-grid {
    margin-top: 40px;
    display: flex;
    flex-direction: column;
  }

  .link-card {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 24px 0;
    border-bottom: 1px solid var(--chalk-faint);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .link-card:first-child { border-top: 1px solid var(--chalk-faint); }
  .link-card:hover { opacity: 0.7; }

  .link-platform {
    font-family: "Instrument Sans", sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--chalk-bright);
    min-width: 120px;
  }

  .link-handle {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--chalk-dim);
    flex: 1;
  }

  .link-arrow {
    font-family: "JetBrains Mono", monospace;
    color: var(--warm);
  }

  @media (max-width: 768px) {
    .bio p {
      font-size: clamp(14px, 1.4vw, 16px);
      line-height: 1.8;
    }

    .timeline-item {
      flex-direction: column;
      gap: 8px;
      padding: 24px 0;
    }

    .timeline-meta {
      width: 100%;
      flex-direction: row;
      align-items: center;
      gap: 12px;
    }

    .timeline-meta .num {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--warm);
      min-width: 30px;
    }

    .timeline-meta .timeline-date {
      font-size: 10px;
      letter-spacing: 1px;
    }

    .timeline-body h2 {
      font-size: clamp(16px, 1.8vw, 20px);
    }

    .timeline-company {
      font-size: 11px;
    }

    .timeline-body p:last-child {
      font-size: 13px;
    }

    .link-card {
      gap: 12px;
      padding: 16px 0;
      flex-wrap: wrap;
    }

    .link-platform {
      font-size: 12px;
      min-width: auto;
    }

    .link-handle {
      font-size: 11px;
      flex: auto;
    }
  }
</style>
