---
import Base from '../layouts/Base.astro';
---
<Base title="About — Jesse Stanger" description="About Jesse Stanger.">
  <section class="page-hero">
    <p class="label fade-up fade-up-1">about</p>
    <h1 class="fade-up fade-up-2">The engineer<br/>behind the code.</h1>
  </section>

  <section class="section-narrow">
    <div class="divider"></div>
    <div class="bio">
      <p>
        I'm a Senior Full Stack Software Engineer based in <strong>Melbourne</strong> with 8 years of experience.
        I operate at the forefront of AI tooling, and have accelerated my teams' and my own throughput, quality, and accuracy by factors.
        My attention to detail is unmatched, and I have a very strong async working style.
      </p>
      <p>
        Currently at <strong>Versent</strong> working on full-stack engineering challenges. I enjoy technical problem solving,
        automating repetitions, mentoring juniors, and bringing ownership to entire epics—reliably delivering on time
        and exceeding expectations.
      </p>
      <p>
        My messages are hyperlinked so everyone can follow along. I reliably return to ongoing conversations and have
        a track record for ownership across distributed teams. I believe in simple, honest code and working with people
        who care about quality.
      </p>
    </div>
  </section>

  <section class="section-narrow">
    <div class="divider"></div>
    <p class="label">experience</p>
    <div class="timeline">
      <div class="timeline-item">
        <div class="timeline-meta">
          <span class="num">now</span>
          <span class="timeline-date">Oct 2024 —</span>
        </div>
        <div class="timeline-body">
          <h3>Senior Software Engineer</h3>
          <p class="timeline-company">Versent</p>
          <p>Working with many different companies on their most difficult challenges. Everywhere from startups to major enterprise, applying full-stack engineering to distributed systems and infrastructure challenges.</p>
        </div>
      </div>
      <div class="timeline-item">
        <div class="timeline-meta">
          <span class="num">prev</span>
          <span class="timeline-date">2023 — 2024</span>
        </div>
        <div class="timeline-body">
          <h3>Senior Software Engineer</h3>
          <p class="timeline-company">Shell Energy Australia — UX Platform</p>
          <p>Responsible for a React/TypeScript microfrontend platform and shared component library serving multiple product teams. Provided technical guidance on design systems, collaborated with downstream teams, and architected new features across the SDLC.</p>
        </div>
      </div>
      <div class="timeline-item">
        <div class="timeline-meta">
          <span class="num">prev</span>
          <span class="timeline-date">2022 — 2023</span>
        </div>
        <div class="timeline-body">
          <h3>Software Engineer</h3>
          <p class="timeline-company">Redbubble — Artist Experience</p>
          <p>Worked on a bleeding-edge platform improving the artist marketplace experience. Introduced dynamic rendering fidelity to the Three.js pipeline, migrated to React Three Fiber, and improved WebGL 2.0 cross-browser compatibility.</p>
        </div>
      </div>
      <div class="timeline-item">
        <div class="timeline-meta">
          <span class="num">prev</span>
          <span class="timeline-date">2021 — 2022</span>
        </div>
        <div class="timeline-body">
          <h3>Senior Full Stack Developer</h3>
          <p class="timeline-company">Roubler</p>
          <p>Architected and deployed OAuth 2.0 and OpenID Connect Provider (Ory Hydra) to production at scale. Test-driven development on mission-critical systems for billing, expenses, leave, and timesheets.</p>
        </div>
      </div>
      <div class="timeline-item">
        <div class="timeline-meta">
          <span class="num">prev</span>
          <span class="timeline-date">2020 — 2021</span>
        </div>
        <div class="timeline-body">
          <h3>Senior Software Developer</h3>
          <p class="timeline-company">Easier Australia</p>
          <p>Implemented secure, repeatable solutions for secret management, identity/access management, and DevOps on Kubernetes using infrastructure-as-code. Built complex Dockerized application ecosystems and orchestrated deployments to AWS.</p>
        </div>
      </div>
      <div class="timeline-item">
        <div class="timeline-meta">
          <span class="num">edu</span>
          <span class="timeline-date">2014 — 2017</span>
        </div>
        <div class="timeline-body">
          <h3>B. Information Technology / B. Business</h3>
          <p class="timeline-company">Queensland University of Technology</p>
          <p>Majored in Computer Science and Marketing. Built a foundation in systems thinking, design, and the intersection of technology and business.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-narrow">
    <div class="divider"></div>
    <p class="label">find me</p>
    <div class="links-grid">
      <a href="https://github.com/stangahh" target="_blank" rel="noopener" class="link-card">
        <span class="link-platform">GitHub</span>
        <span class="link-handle">@stangahh</span>
        <span class="link-arrow">→</span>
      </a>
      <a href="https://www.linkedin.com/in/stangahh/" target="_blank" rel="noopener" class="link-card">
        <span class="link-platform">LinkedIn</span>
        <span class="link-handle">/in/stangahh</span>
        <span class="link-arrow">→</span>
      </a>
      <a href="mailto:me@stangahh.dev" target="_blank" rel="noopener" class="link-card">
        <span class="link-platform">Email</span>
        <span class="link-handle">me@stangahh.dev</span>
        <span class="link-arrow">→</span>
      </a>
    </div>
  </section>
</Base>

<style>
.bio {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding-top: 40px;
  }

  .bio p {
    font-size: clamp(16px, 1.6vw, 19px);
    font-weight: 300;
    line-height: 1.9;
    color: rgba(235,230,220,.8);
  }

  .timeline {
    margin-top: 40px;
    display: flex;
    flex-direction: column;
  }

  .timeline-item {
    display: flex;
    gap: 32px;
    padding: 36px 0;
    border-bottom: 1px solid var(--chalk-faint);
  }

  .timeline-item:first-child { border-top: 1px solid var(--chalk-faint); }

  .timeline-meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 80px;
  }

.timeline-date {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--chalk-dim);
  }

  .timeline-body { flex: 1; }

  .timeline-body h3 {
    font-size: clamp(18px, 2vw, 24px);
    margin-bottom: 4px;
  }

  .timeline-company {
    font-family: "Instrument Sans", sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--warm);
    margin-bottom: 12px;
    display: block;
  }

  .timeline-body p:last-child {
    font-size: 14px;
    color: var(--chalk-dim);
    line-height: 1.7;
  }

  .links-grid {
    margin-top: 40px;
    display: flex;
    flex-direction: column;
  }

  .link-card {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 24px 0;
    border-bottom: 1px solid var(--chalk-faint);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .link-card:first-child { border-top: 1px solid var(--chalk-faint); }
  .link-card:hover { opacity: 0.7; }

  .link-platform {
    font-family: "Instrument Sans", sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--chalk-bright);
    min-width: 120px;
  }

  .link-handle {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--chalk-dim);
    flex: 1;
  }

  .link-arrow {
    font-family: "JetBrains Mono", monospace;
    color: var(--warm);
  }

  @media (max-width: 768px) {
    .bio p {
      font-size: clamp(14px, 1.4vw, 16px);
      line-height: 1.8;
    }

    .timeline-item {
      gap: 16px;
      padding: 24px 0;
    }

    .timeline-meta {
      min-width: 60px;
    }

    .timeline-body h3 {
      font-size: clamp(16px, 1.8vw, 20px);
    }

    .timeline-company {
      font-size: 11px;
    }

    .timeline-body p:last-child {
      font-size: 13px;
    }

    .link-card {
      gap: 12px;
      padding: 16px 0;
      flex-wrap: wrap;
    }

    .link-platform {
      font-size: 12px;
      min-width: auto;
    }

    .link-handle {
      font-size: 11px;
      flex: auto;
    }
  }
</style>
