---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('writing');
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];

function getDateId(d: Date) {
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`;
}
function getDateGroup(d: Date) {
  return `${MONTHS[d.getMonth()]} ${d.getFullYear()}`;
}

type PostEntry = typeof allPosts[number];
const grouped: Record<string, { label: string; id: string; posts: PostEntry[] }> = {};
for (const post of allPosts) {
  const dateId = getDateId(post.data.date);
  const dateGroup = getDateGroup(post.data.date);
  if (!grouped[dateId]) grouped[dateId] = { label: dateGroup, id: dateId, posts: [] };
  grouped[dateId].posts.push(post);
}
const groups = Object.values(grouped);
const categories = ["all", "technical", "essays"];
---
<Base title="Writing — Jesse Stanger" description="Things I've written.">
  <div class="writing-wrap">

    <header class="editorial-hero">
      <p class="label fade-up fade-up-1">writing</p>
      <h1 class="fade-up fade-up-2">The <em>Archive</em></h1>
      <p class="hero-sub fade-up fade-up-3">{allPosts.length} {allPosts.length === 1 ? 'piece' : 'pieces'} across {groups.length} {groups.length === 1 ? 'month' : 'months'}</p>
    </header>

    <div class="tab-controls">
      <div class="tabs">
        {categories.map((cat, i) => (
          <button class:list={["tab-btn", { active: i === 0 }]} data-cat={cat}>{cat}</button>
        ))}
      </div>
      <input type="text" class="search-input" id="searchInput" placeholder="search..." autocomplete="off" />
    </div>

    <div class="writing-layout">
      <aside class="writing-sidebar" id="writingSidebar">
        {groups.map((g, i) => (
          <a class:list={["sidebar-item", { active: i === 0 }]} href={`#${g.id}`} data-target={g.id}>
            <span class="sidebar-label">{g.label}</span>
          </a>
        ))}
      </aside>

      <div class="writing-main" id="writingMain">
        {groups.map(g => (
          <section class="date-group" id={g.id} data-group={g.id}>
            <h2 class="date-heading">{g.label}</h2>
            {g.posts.map(post => (
              <article
                class="resource-card"
                data-cat={post.data.category}
                data-search={`${post.data.title} ${post.data.tags.join(' ')} ${post.data.category}`.toLowerCase()}
              >
                <div class="resource-badges">
                  <span class="resource-badge">{post.data.category}</span>
                  {post.data.tags.map(t => <span class="resource-badge">{t}</span>)}
                </div>
                <h3 class="resource-title">
                  <a href={`/writing/${post.id}`}>{post.data.title}</a>
                </h3>
                <div class="resource-body">
                  <p>{post.data.description}</p>
                </div>
                <div class="resource-meta">
                  <span class="resource-date" data-utc={post.data.date.toISOString()}>{post.data.date.toISOString()}</span>
                </div>
                <div class="resource-tags">
                  {post.data.tags.map(t => <span class="resource-tag">{t}</span>)}
                </div>
              </article>
            ))}
          </section>
        ))}
        <p class="no-results" id="noResults">No posts match that filter.</p>
      </div>
    </div>

  </div>
</Base>

<style>
  .writing-wrap {
    padding-top: 80px; /* nav height */
  }

.hero-sub {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 3px;
    color: var(--chalk-dim);
    margin-top: 20px;
    text-transform: uppercase;
  }

  /* ── Tab bar ── */
  .tab-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 clamp(24px, 5vw, 80px);
    border-bottom: 1px solid var(--chalk-faint);
    max-width: 1200px;
    margin: 0 auto;
    gap: 24px;
  }

  .tabs {
    display: flex;
    gap: 0;
  }

  .tab-btn {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--chalk-dim);
    background: none;
    border: 1px solid transparent;
    border-bottom: none;
    padding: 14px 18px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    position: relative;
    bottom: -1px; /* sit on the border-bottom line */
  }

  .tab-btn:hover { color: var(--chalk); }

  .tab-btn.active {
    color: var(--warm);
    border-color: var(--warm-border);
    background: rgba(196, 122, 58, 0.04);
  }

  .search-input {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 2px;
    background: none;
    border: none;
    border-bottom: 1px solid var(--chalk-faint);
    color: var(--chalk);
    padding: 8px 4px;
    width: 180px;
    outline: none;
    transition: border-color 0.2s;
  }

  .search-input::placeholder { color: var(--chalk-faint); }
  .search-input:focus { border-color: var(--warm-border); }

  /* ── Two-column layout ── */
  .writing-layout {
    display: flex;
    max-width: 1200px;
    margin: 0 auto;
    min-height: 60vh;
  }

  /* ── Sidebar ── */
  .writing-sidebar {
    width: 200px;
    flex-shrink: 0;
    padding: 24px 0;
    border-right: 1px solid var(--chalk-faint);
    position: sticky;
    top: 80px;
    height: fit-content;
    max-height: calc(100vh - 80px);
    overflow-y: auto;
  }

  .sidebar-item {
    display: block;
    padding: 6px 16px 6px 14px;
    margin-bottom: 2px;
    border-left: 2px solid transparent;
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 1px;
    color: var(--chalk-dim);
    text-decoration: none;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .sidebar-item:hover { color: var(--chalk); }

  .sidebar-item.active {
    border-left-color: var(--warm);
    background: rgba(196, 122, 58, 0.05);
    color: var(--chalk);
  }

  .sidebar-label { display: block; }

  /* ── Main feed ── */
  .writing-main {
    flex: 1;
    padding: 24px 30px 80px;
    min-width: 0;
  }

  .date-group { margin-bottom: 24px; }

  .date-heading {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--chalk-dim);
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--chalk-faint);
    font-weight: 400;
  }

  /* ── Resource card ── */
  .resource-card {
    padding: 28px 0;
    border-bottom: 1px solid var(--chalk-faint);
  }

  .resource-card:last-of-type { border-bottom: none; }


  .resource-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 12px;
  }

  .resource-badge {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--cool);
    background: rgba(14, 165, 201, 0.08);
    border: 0.667px solid rgba(14, 165, 201, 0.2);
    padding: 3px 10px;
    display: inline-block;
    text-decoration: none;
  }

  .resource-title {
    font-family: "Cormorant Garamond", serif;
    font-size: 28px;
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 10px;
    color: var(--chalk-bright);
  }

  .resource-title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }

  .resource-title a:hover { color: var(--warm); }

  .resource-body p {
    font-size: 15px;
    color: var(--chalk-dim);
    line-height: 1.75;
    max-width: 680px;
  }

  .resource-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 14px;
    margin-bottom: 12px;
  }

  .resource-date {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 1px;
    color: rgba(235, 230, 220, 0.5);
  }

  .resource-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .resource-tag {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 1px;
    color: var(--chalk);
    border: 0.667px solid rgba(235, 230, 220, 0.12);
    padding: 2px 8px;
    display: inline-block;
  }

  /* ── States ── */
  .resource-card[hidden] { display: none; }

  .no-results {
    display: none;
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    letter-spacing: 2px;
    color: var(--chalk-dim);
    padding: 48px 0;
    text-transform: uppercase;
  }

  .no-results.visible { display: block; }

  .date-group[hidden] { display: none; }

  @media (max-width: 768px) {
    .writing-wrap {
      padding-top: 60px;
    }

    .tab-controls {
      flex-wrap: wrap;
      padding: 0 16px;
      gap: 0;
    }

    .tabs {
      flex-wrap: wrap;
      flex: 1 1 100%;
    }

    .search-input {
      width: 100%;
      flex: 1 1 100%;
      padding: 10px 4px;
      border-top: 1px solid var(--chalk-faint);
      border-bottom: 1px solid var(--chalk-faint);
      margin-bottom: 4px;
    }

    .writing-layout {
      flex-direction: column;
      gap: 32px;
    }

    .writing-sidebar {
      width: 100%;
      order: -1;
    }

    .resource-card {
      padding: 20px 16px;
    }

    .resource-title {
      font-size: clamp(18px, 4vw, 24px);
    }

    .resource-body p {
      font-size: 14px;
    }

    .resource-badge {
      font-size: 10px;
    }

    .resource-tag {
      font-size: 9px;
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const cards = document.querySelectorAll<HTMLElement>('.resource-card');
  const groups = document.querySelectorAll<HTMLElement>('.date-group');
  const noResults = document.getElementById('noResults');
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const sidebarItems = document.querySelectorAll<HTMLAnchorElement>('.sidebar-item');

  let activeCat = 'all';
  let searchTerm = '';

  function filter() {
    let visible = 0;

    groups.forEach(group => {
      let groupVisible = 0;
      const groupCards = group.querySelectorAll<HTMLElement>('.resource-card');
      groupCards.forEach(card => {
        const catMatch = activeCat === 'all' || card.dataset.cat === activeCat;
        const searchMatch = !searchTerm || (card.dataset.search || '').includes(searchTerm);
        const show = catMatch && searchMatch;
        card.hidden = !show;
        if (show) { groupVisible++; visible++; }
      });
      group.hidden = groupVisible === 0;
    });

    if (noResults) {
      noResults.classList.toggle('visible', visible === 0);
    }
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      activeCat = tab.dataset.cat || 'all';
      filter();
    });
  });

  searchInput?.addEventListener('input', () => {
    searchTerm = searchInput.value.toLowerCase().trim();
    filter();
  });

  // Sidebar: highlight active section on scroll
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const id = entry.target.id;
        sidebarItems.forEach(item => {
          item.classList.toggle('active', item.dataset.target === id);
        });
      }
    });
  }, { rootMargin: '-20% 0px -70% 0px' });

  groups.forEach(g => observer.observe(g));

  // Local timezone tooltips
  document.querySelectorAll<HTMLElement>('.resource-date[data-utc]').forEach(el => {
    el.textContent = new Date(el.dataset.utc!).toString();
  });

  // Smooth sidebar scroll on click (prevent default + manual scroll)
  sidebarItems.forEach(item => {
    item.addEventListener('click', e => {
      e.preventDefault();
      const id = item.dataset.target;
      if (id) {
        const target = document.getElementById(id);
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
</script>
